<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Memórias de um Pé Vermelho - Clebson Ribeiro</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="192x192" href="https://clebsonribeiro.com.br/wp-content/uploads/2023/10/cropped-icon1-1-192x192.png">
    <link rel="apple-touch-icon" href="https://clebsonribeiro.com.br/wp-content/uploads/2023/10/cropped-icon1-1-192x192.png">
    
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <div class="container">
        <!-- Background overlay -->
        <div class="background-overlay"></div>
        
        <!-- Welcome Overlay - Aparece ao entrar no site -->
        <div class="welcome-overlay" id="welcomeOverlay">
            <div class="welcome-content">
                <h2>🎵 Bem-vindo ao EPK</h2>
                <h3>Memórias de um Pé Vermelho</h3>
                <p>Uma experiência musical imersiva com rádio vintage</p>
                
                <div class="instructions">
                    <div class="instruction-item">
                        <span class="instruction-icon">🔘</span>
                        <p><strong>1º botão</strong> - Liga/Desliga o rádio</p>
                    </div>
                    <div class="instruction-item">
                        <span class="instruction-icon">▶️</span>
                        <p><strong>2º botão</strong> - Play/Pause</p>
                    </div>
                    <div class="instruction-item">
                        <span class="instruction-icon">⏮️</span>
                        <p><strong>3º botão</strong> - Música anterior</p>
                    </div>
                    <div class="instruction-item">
                        <span class="instruction-icon">⏭️</span>
                        <p><strong>4º botão</strong> - Próxima música</p>
                    </div>
                </div>
                
                <button class="start-button" id="startButton">
                    Começar Experiência
                </button>
                
                <p class="tip">💡 Dica: Use as setas do teclado para navegar</p>
            </div>
        </div>
        
        <!-- Main content -->
        <div class="content">
            <!-- Header -->
            <header class="header">
                <h1 class="album-title">Memórias de um pé vermelho</h1>
                <h2 class="artist-name">Clebson Ribeiro</h2>
            </header>

            <!-- Radio Interface -->
            <div class="radio-container">
                <div class="radio-wrapper">
                    <img src="assets/radio.png" alt="Rádio Vintage" class="radio-image" id="radioImage">
                    
                    <!-- Flame effect overlay -->
                    <div class="flame-overlay"></div>
                    
                    <!-- Interactive hotspots -->
                    <div class="radio-controls">
                        <!-- Power button (primeiro botão) -->
                        <button class="hotspot power-btn" id="powerBtn" title="Ligar/Desligar">
                            <!-- Indicador pulsante -->
                            <span class="power-hint" id="powerHint">
                                <span class="hint-text">Clique aqui para começar</span>
                                <span class="hint-arrow">👆</span>
                            </span>
                        </button>
                        
                        <!-- Play/Pause button (segundo botão) -->
                        <button class="hotspot play-btn" id="playBtn" title="Play/Pause"></button>
                        
                        <!-- Previous button (terceiro botão) -->
                        <button class="hotspot prev-btn" id="prevBtn" title="Anterior"></button>
                        
                        <!-- Next button (quarto botão) -->
                        <button class="hotspot next-btn" id="nextBtn" title="Próxima"></button>
                    </div>

                    <!-- Status indicator -->
                    <div class="radio-status" id="radioStatus">
                        <span class="status-text">Clique no primeiro botão para ligar o rádio</span>
                    </div>
                </div>

                <!-- Now Playing info -->
                <div class="now-playing" id="nowPlaying">
                    <div class="track-info">
                        <span class="track-number" id="trackNumber">-</span>
                        <span class="track-name" id="trackName">Aguardando...</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" id="progressFill"></div>
                    </div>
                    <div class="time-display">
                        <span id="currentTime">0:00</span>
                        <span id="totalTime">0:00</span>
                    </div>
                </div>
            </div>

            <!-- Tracklist -->
            <div class="tracklist-container">
                <h3>Faixas do Álbum</h3>
                <ol class="tracklist" id="tracklist">
                    <li data-track="0">
                        <span class="track-title">Cabocla / Chico Mineiro / Nhambu Xita</span>
                        <span class="play-count" data-count-id="0">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="1">
                        <span class="track-title">Romaria</span>
                        <span class="play-count" data-count-id="1">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="2">
                        <span class="track-title">Tocando em Frente</span>
                        <span class="play-count" data-count-id="2">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="3">
                        <span class="track-title">Amargurado</span>
                        <span class="play-count" data-count-id="3">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="4">
                        <span class="track-title">Antonio e Natália</span>
                        <span class="play-count" data-count-id="4">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="5">
                        <span class="track-title">Vaca Estrela e Boi Fubá</span>
                        <span class="play-count" data-count-id="5">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="6">
                        <span class="track-title">Disparada</span>
                        <span class="play-count" data-count-id="6">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="7">
                        <span class="track-title">Mercedita</span>
                        <span class="play-count" data-count-id="7">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="8">
                        <span class="track-title">Vide Vida Marvada</span>
                        <span class="play-count" data-count-id="8">👂 <span class="count-number">0</span></span>
                    </li>
                    <li data-track="9">
                        <span class="track-title">A Terra e o Tempo</span>
                        <span class="play-count" data-count-id="9">👂 <span class="count-number">0</span></span>
                    </li>
                </ol>
            </div>

            <!-- Footer -->
            <footer class="footer">
                <p>&copy; 2026 Clebson Ribeiro - Todos os direitos reservados</p>
            </footer>
        </div>
    </div>

    <!-- Audio elements -->
    <audio id="mainAudio" preload="metadata"></audio>
    <audio id="effectAudio" preload="auto"></audio>

    <script src="js/audio-player.js"></script>
    <script src="js/radio-interface.js"></script>
</body>
</html>
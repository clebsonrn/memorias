/**
 * Radio Interface - Mem¾rias de um Pķ Vermelho
 * Conecta os controles visuais do rßdio ao player de ßudio
 */

document.addEventListener('DOMContentLoaded', () => {
    // Controle do Welcome Overlay
    initWelcomeOverlay();
    
    // Aguardar player estar pronto
    const checkPlayer = setInterval(() => {
        if (typeof player !== 'undefined') {
            clearInterval(checkPlayer);
            initRadioControls();
        }
    }, 100);
});

/**
 * Inicializa o overlay de boas-vindas
 */
function initWelcomeOverlay() {
    const welcomeOverlay = document.getElementById('welcomeOverlay');
    const startButton = document.getElementById('startButton');
    const powerHint = document.getElementById('powerHint');
    
    // BotŃo para comeńar
    startButton.addEventListener('click', () => {
        // Fade out do overlay
        welcomeOverlay.classList.add('hidden');
        
        // Remove ap¾s animańŃo
        setTimeout(() => {
            welcomeOverlay.style.display = 'none';
        }, 500);
        
        // Mostra hint no botŃo power ap¾s 1 segundo
        setTimeout(() => {
            if (powerHint && !player.isOn) {
                powerHint.classList.add('show');
                
                // Remove hint ap¾s 10 segundos ou quando clicar
                setTimeout(() => {
                    powerHint.classList.remove('show');
                }, 10000);
            }
        }, 1000);
    });
}

function initRadioControls() {
    console.log('Inicializando controles do rßdio...');
    
    // Bot§es do rßdio
    const powerBtn = document.getElementById('powerBtn');
    const playBtn = document.getElementById('playBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    
    // Tracklist
    const tracklistItems = document.querySelectorAll('.tracklist li');
    
    // Event Listeners
    
    // Power button - Liga/Desliga o rßdio
    powerBtn.addEventListener('click', () => {
        console.log('Power button clicked');
        
        // Remove hint se estiver visĒvel
        const powerHint = document.getElementById('powerHint');
        if (powerHint) {
            powerHint.classList.remove('show');
        }
        
        if (player.isOn) {
            player.powerOff();
            addButtonFeedback(powerBtn, 'power-off');
        } else {
            player.powerOn();
            addButtonFeedback(powerBtn, 'power-on');
        }
    });
    
    // Play/Pause button
    playBtn.addEventListener('click', () => {
        console.log('Play button clicked');
        player.togglePlay();
        addButtonFeedback(playBtn, 'play');
    });
    
    // Previous button
    prevBtn.addEventListener('click', () => {
        console.log('Previous button clicked');
        player.playPrevious();
        addButtonFeedback(prevBtn, 'prev');
    });
    
    // Next button
    nextBtn.addEventListener('click', () => {
        console.log('Next button clicked');
        player.playNext();
        addButtonFeedback(nextBtn, 'next');
    });
    
    // Tracklist items
    tracklistItems.forEach((item, index) => {
        item.addEventListener('click', () => {
            console.log(`Tracklist item ${index} clicked`);
            player.playTrack(index);
        });
    });
    
    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
        switch(e.key) {
            case ' ':
                e.preventDefault();
                player.togglePlay();
                break;
            case 'ArrowLeft':
                e.preventDefault();
                player.playPrevious();
                break;
            case 'ArrowRight':
                e.preventDefault();
                player.playNext();
                break;
        }
    });
    
    console.log('Controles do rßdio inicializados!');
    console.log('Atalhos de teclado:');
    console.log('- Espańo: Play/Pause');
    console.log('- Seta esquerda: Anterior');
    console.log('- Seta direita: Pr¾xima');
}

/**
 * Adiciona feedback visual ao clicar nos bot§es
 */
function addButtonFeedback(button, action) {
    button.style.transform = 'scale(0.9)';
    
    setTimeout(() => {
        button.style.transform = 'scale(1)';
    }, 150);
    
    // Som de clique (opcional)
    playClickSound();
}

/**
 * Toca som de clique mecŌnico (opcional)
 */
function playClickSound() {
    // VocĻ pode adicionar um arquivo de som de clique mecŌnico aqui
    // const clickAudio = new Audio('assets/click.mp3');
    // clickAudio.volume = 0.3;
    // clickAudio.play();
}

/**
 * Mostra tooltip ao passar o mouse sobre os bot§es
 */
function initTooltips() {
    const buttons = document.querySelectorAll('.hotspot');
    
    buttons.forEach(button => {
        button.addEventListener('mouseenter', (e) => {
            const tooltip = e.target.getAttribute('title');
            if (tooltip) {
                // VocĻ pode criar tooltips customizados aqui se quiser
                console.log('Tooltip:', tooltip);
            }
        });
    });
}

// Inicializar tooltips
initTooltips();

/**
 * Detecta inatividade e exibe dica
 */
let inactivityTimer;
function resetInactivityTimer() {
    clearTimeout(inactivityTimer);
    
    inactivityTimer = setTimeout(() => {
        if (!player.isOn) {
            player.showStatus('?? Dica: Clique no primeiro botŃo para comeńar');
        }
    }, 30000); // 30 segundos
}

// Reset timer em qualquer interańŃo
document.addEventListener('click', resetInactivityTimer);
document.addEventListener('keypress', resetInactivityTimer);
resetInactivityTimer();